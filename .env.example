ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Integrations (set MODE to switch from mock to real) ---
GITHUB_MODE=mock            # mock | rest
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

SLACK_MODE=mock             # mock | webhook | bot   (bot enables streaming updates)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=            # xoxb-... — required for `bot` mode (chat.update)
SLACK_CHANNEL=#incidents

METRICS_MODE=mock           # mock | datadog
DATADOG_API_KEY=
DATADOG_APP_KEY=

# --- Storage ---
RUNBOOKS_DIR=./runbooks
POSTMORTEM_DIR=./postmortems
DB_PATH=./incidents.db

# --- Webhook auth (any of these is sufficient) ---
WEBHOOK_TOKEN=change-me
DATADOG_WEBHOOK_SECRET=
PAGERDUTY_WEBHOOK_SECRET=
GENERIC_WEBHOOK_SECRET=

# --- Rate limiting ---
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_SECONDS=60

# --- Deduplication ---
DEDUP_BUCKET_MINUTES=15
DEDUP_TTL_SECONDS=3600

# --- Remediation executor ---
REMEDIATION_MODE=mock       # mock | shell   (shell only runs allow-listed commands)
REMEDIATION_ALLOWED_COMMANDS=feature-flag,kubectl,deploy
REMEDIATION_TIMEOUT_SECONDS=30

# --- Post-remediation verification ---
VERIFICATION_ENABLED=true
VERIFICATION_TOTAL_MINUTES=10
VERIFICATION_POLL_SECONDS=30

# --- Observability ---
LOG_LEVEL=INFO
OTEL_SERVICE_NAME=incident-response
# If set, spans are exported via OTLP HTTP to this endpoint (requires opentelemetry-*)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
